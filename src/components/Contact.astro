<section id="contact" class="relative px-8 py-32 lg:px-16">
  <h2 class="font-heading text-accent mb-8 text-5xl font-thin">Contact</h2>

  <!-- Status Notification Container -->
  <div
    id="form-status"
    class="mb-6 hidden mx-auto max-w-xl border p-4 text-sm font-light transition-all"
  >
  </div>

  <form
    action="/contact.php"
    method="POST"
    class="relative z-10 flex flex-col items-center max-w-4xl mx-auto gap-6 bg-black lg:p-2"
  >
    {/* HONEYPOT FIELD (Hidden from humans) */}
    <div class="hidden" aria-hidden="true">
      <input type="text" name="website_hp" tabindex="-1" autocomplete="off" />
    </div>

    <div class="flex flex-col justify-center gap-6 lg:flex-row lg:gap-12">
      <!-- Name Field -->
      <div class="flex items-stretch">
        <label
          for="name"
          class="flex w-28 items-center border border-[#e59053] bg-[#7f3500] px-5 text-lg select-none lg:w-32"
        >
          name
        </label>
        <input
          id="name"
          type="text"
          name="name"
          required
          maxlength="100"
          class="focus:border-accent focus:ring-accent w-full border border-l-0 border-white/75 p-3 text-lg transition outline-none focus:ring-1 lg:w-64"
        />
      </div>

      <!-- Email Field -->
      <div class="flex items-stretch">
        <label
          for="email"
          class="flex w-28 items-center border border-[#e59053] bg-[#7f3500] px-5 text-lg select-none lg:w-32"
        >
          email
        </label>
        <input
          id="email"
          type="email"
          name="email"
          required
          maxlength="100"
          class="focus:border-accent focus:ring-accent w-full border border-l-0 border-white/75 p-3 text-lg transition outline-none focus:ring-1 lg:w-64"
        />
      </div>
    </div>

    <!-- Message Field -->
    <textarea
      id="message"
      rows="5"
      name="message"
      required
      maxlength="3000"
      placeholder="message"
      class="focus:border-accent w-full focus:ring-accent border border-white/75 p-3 text-lg transition outline-none focus:ring-1"
    ></textarea>

    <!-- Submit Button -->
    <button
      type="submit"
      class="border-accent/15 bg-accent/50 hover:bg-accent w-fit cursor-pointer border p-3 px-12 text-lg transition hover:text-black"
    >
      send
    </button>
  </form>
</section>

<!-- Client-side script to show status message based on URL -->
<script>
  const params = new URLSearchParams(window.location.search);
  const status = params.get("status");
  const statusEl = document.getElementById("form-status");

  if (status && statusEl) {
    statusEl.classList.remove("hidden");

    if (status === "success") {
      statusEl.classList.add(
        "border-green-500/50",
        "bg-green-500/10",
        "text-green-400",
      );
      statusEl.textContent =
        "Thank you! Your message has been sent successfully.";
    } else if (status === "rate_limited") {
      statusEl.classList.add(
        "border-yellow-500/50",
        "bg-yellow-500/10",
        "text-yellow-400",
      );
      statusEl.textContent =
        "Please wait a minute before sending another message.";
    } else if (status === "invalid_email") {
      statusEl.classList.add(
        "border-red-500/50",
        "bg-red-500/10",
        "text-red-400",
      );
      statusEl.textContent = "Please provide a valid email address.";
    } else {
      statusEl.classList.add(
        "border-red-500/50",
        "bg-red-500/10",
        "text-red-400",
      );
      statusEl.textContent = "An error occurred. Please try again.";
    }
  }
</script>
