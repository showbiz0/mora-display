---
import { Image } from "astro:assets";
import logoImage from "../assets/logo.png";

const navLinks = [
  { name: "Corporate Philosophy", href: "#corporate-philosophy" },
  { name: "Our Strengths", href: "#our-strengths" },
  { name: "History", href: "#history" },
  { name: "Projects", href: "#projects" },
  { name: "Gallery", href: "#gallery" },
  { name: "Contact", href: "#contact" },
];
---

<!-- Fixed Header -->
<header
  id="main-header"
  class="fixed top-0 left-0 z-50 flex w-full translate-y-0 items-center justify-between bg-black/90 px-8 py-6 backdrop-blur-sm transition-transform duration-300 md:px-16"
>
  <a href="/" class="text-lg font-semibold tracking-wide text-white">
    <Image
      src={logoImage}
      alt="Mora Display Logo"
      class="h-8 w-auto md:h-10"
      loading="eager"
    />
  </a>

  <button
    id="open-menu-btn"
    type="button"
    class="group flex cursor-pointer items-center gap-3 transition-opacity hover:opacity-80"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-overlay"
  >
    <span class="flex flex-col gap-[6px]">
      <span class="bg-accent block h-[2px] w-7"></span>
      <span class="bg-accent block h-[2px] w-7"></span>
      <span class="bg-accent block h-[2px] w-7"></span>
    </span>
    <span class="text-base font-medium text-white">Menu</span>
  </button>
</header>

<!-- Full-Screen Navigation Overlay (Added 'invisible' to default classes) -->
<div
  id="nav-overlay"
  class="pointer-events-none invisible fixed inset-0 z-[60] flex flex-col justify-between bg-black/95 px-8 py-8 opacity-0 backdrop-blur-md transition-all duration-300 md:px-16"
  aria-hidden="true"
>
  <div class="flex items-center justify-between">
    <a href="/" class="text-lg font-semibold tracking-wide text-white">
      <Image
        src={logoImage}
        alt="Mora Display Logo"
        class="h-8 w-auto md:h-10"
        loading="eager"
      />
    </a>

    <button
      id="close-menu-btn"
      type="button"
      class="group flex cursor-pointer items-center gap-3 transition-opacity hover:opacity-80"
      aria-label="Close menu"
    >
      <span class="text-base font-medium text-white">Close</span>
      <span class="relative flex h-6 w-6 items-center justify-center">
        <span class="bg-accent absolute h-[2px] w-6 rotate-45"></span>
        <span class="bg-accent absolute h-[2px] w-6 -rotate-45"></span>
      </span>
    </button>
  </div>

  <nav class="mx-auto my-auto w-fit py-12">
    <ul
      class="grid gap-6 text-left md:grid-cols-2 md:gap-x-16 md:gap-y-10 lg:gap-x-24"
    >
      {
        navLinks.map((link, index) => (
          <li>
            <a
              href={link.href}
              class="nav-link group hover:text-accent inline-flex items-baseline gap-4 text-2xl font-thin tracking-wide text-white transition-colors md:text-3xl lg:text-4xl"
            >
              <span class="text-accent/60 group-hover:text-accent font-mono text-xs">
                0{index + 1}
              </span>
              <span>{link.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div
    class="flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-6 text-xs font-light text-white/40 sm:text-sm md:flex-row"
  >
    <p>Mora Display — Exhibition & Architecture Solutions</p>
    <p>© {new Date().getFullYear()} Mora Display. All rights reserved.</p>
  </div>
</div>

<script>
  const openBtn = document.getElementById("open-menu-btn");
  const closeBtn = document.getElementById("close-menu-btn");
  const overlay = document.getElementById("nav-overlay");
  const navLinks = document.querySelectorAll(".nav-link");

  function openMenu() {
    if (!overlay || !openBtn) return;
    overlay.classList.remove("opacity-0", "pointer-events-none", "invisible");
    overlay.classList.add("opacity-100", "pointer-events-auto", "visible");
    openBtn.setAttribute("aria-expanded", "true");
    overlay.setAttribute("aria-hidden", "false");
    document.body.classList.add("overflow-hidden");
  }

  function closeMenu() {
    if (!overlay || !openBtn) return;
    overlay.classList.remove("opacity-100", "pointer-events-auto", "visible");
    overlay.classList.add("opacity-0", "pointer-events-none", "invisible");
    openBtn.setAttribute("aria-expanded", "false");
    overlay.setAttribute("aria-hidden", "true");
    document.body.classList.remove("overflow-hidden");
  }

  openBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);

  navLinks.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      overlay?.getAttribute("aria-hidden") === "false"
    ) {
      closeMenu();
    }
  });
</script>
