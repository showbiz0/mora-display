---
import { Image } from "astro:assets";
import image1 from "../assets/images/gallery-1.png";
import image2 from "../assets/images/gallery-2.png";
import image3 from "../assets/images/gallery-3.png";
import image4 from "../assets/images/gallery-4.jpg";
import image5 from "../assets/images/gallery-5.png";

const images = [
  { src: image1, alt: "Gallery image 1" },
  { src: image2, alt: "Gallery image 2" },
  { src: image3, alt: "Gallery image 3" },
  { src: image4, alt: "Gallery image 4" },
  { src: image5, alt: "Gallery image 5" },
];
---

<section class="relative overflow-hidden px-8 py-20 text-white md:px-16">
  <h2 class="font-heading text-accent mb-14 text-center text-5xl font-thin">
    GALLERY
  </h2>

  <div class="gallery-carousel relative mx-auto max-w-[1100px]">
    <!-- Arrow buttons -->
    <button
      type="button"
      class="gallery-prev absolute top-1/2 left-2 z-20 -translate-y-1/2 cursor-pointer rounded-full border border-white/20 bg-black/40 p-3 backdrop-blur-sm transition hover:bg-black/70 md:left-4"
      aria-label="Previous image"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    </button>
    <button
      type="button"
      class="gallery-next absolute top-1/2 right-2 z-20 -translate-y-1/2 cursor-pointer rounded-full border border-white/20 bg-black/40 p-3 backdrop-blur-sm transition hover:bg-black/70 md:right-4"
      aria-label="Next image"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    </button>

    <!-- Swiper root -->
    <div class="swiper gallery-swiper">
      <div class="swiper-wrapper items-center">
        {
          images.map((img) => (
            <div class="swiper-slide !h-[420px] !w-[520px] max-w-[85vw]">
              <Image
                src={img.src}
                alt={img.alt}
                class="h-full w-full object-cover"
                draggable="false"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .gallery-swiper {
    overflow: visible;
  }

  .swiper-slide {
    will-change: transform, filter, opacity;
    transition-property: transform, filter, opacity;
  }

  .swiper-slide img {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, FreeMode, Mousewheel } from "swiper/modules";
  import "swiper/css";

  function initGallery(root: Element) {
    const prevBtn = root.querySelector<HTMLButtonElement>(".gallery-prev");
    const nextBtn = root.querySelector<HTMLButtonElement>(".gallery-next");
    const swiperEl = root.querySelector<HTMLElement>(".gallery-swiper");
    if (!swiperEl) return;

    const swiper = new Swiper(swiperEl, {
      modules: [Navigation, FreeMode, Mousewheel],
      slidesPerView: "auto",
      initialSlide: 2,
      centeredSlides: true,
      spaceBetween: 24,
      grabCursor: true,
      watchSlidesProgress: true,
      freeMode: {
        enabled: true,
        sticky: true,
        momentumRatio: 0.6,
      },
      mousewheel: {
        forceToAxis: true,
      },
      speed: 500,
      on: {
        progress(swiper) {
          swiper.slides.forEach((slideEl) => {
            const progress = (slideEl as any).progress as number;
            const absProgress = Math.abs(progress);

            const scale = Math.max(1 - absProgress * 0.22, 0.72);
            const blur = Math.min(absProgress * 6, 10);
            const opacity = Math.max(1 - absProgress * 0.55, 0.25);
            const translateX = progress * 40;

            slideEl.style.transform = `translateX(${translateX}px) scale(${scale})`;
            slideEl.style.filter = `blur(${blur}px)`;
            slideEl.style.opacity = String(opacity);
            slideEl.style.zIndex = String(10 - Math.round(absProgress * 10));
          });
        },
        setTransition(swiper, duration) {
          swiper.slides.forEach((slideEl) => {
            slideEl.style.transitionDuration = `${duration}ms`;
          });
        },
      },
    });

    prevBtn?.addEventListener("click", () => swiper.slidePrev());
    nextBtn?.addEventListener("click", () => swiper.slideNext());
  }

  document
    .querySelectorAll(".gallery-carousel")
    .forEach((el) => initGallery(el));
</script>
