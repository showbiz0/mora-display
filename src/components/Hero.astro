<section
  id="hero-pin-container"
  class="relative h-screen w-full overflow-hidden bg-black"
>
  <!-- 1. Optimized Video -->
  <video
    autoplay
    loop
    muted
    playsinline
    poster="/mora-display/assets/hero.png"
    class="absolute inset-0 h-full w-full object-cover"
  >
    <source src="/mora-display/assets/hero.webm" type="video/webm" />
    <source src="/mora-display/assets/hero.mp4" type="video/mp4" />
    Your browser does not support HTML5 video.
  </video>

  <!-- 2. SVG Mask Overlay -->
  <div
    id="hero-mask-wrapper"
    class="pointer-events-none absolute inset-0 h-full w-full"
  >
    <svg
      class="h-full w-full"
      viewBox="0 0 1920 1080"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <mask id="hero-text-mask" x="0" y="0" width="100%" height="100%">
          <!-- White background = Overlay stays solid black -->
          <rect width="100%" height="100%" fill="white"></rect>

          <!-- Black text = Cutout hole where video shows through -->
          <g id="hero-text-group" style="transform-origin: 50% 50%;">
            <text
              x="960"
              y="485"
              text-anchor="middle"
              class="font-heading -translate-y-1 fill-black text-[54px] font-extrabold tracking-tight transition-transform md:-translate-y-8 md:text-[92px]"
            >
              From vision to venue
            </text>

            <text
              x="960"
              y="525"
              text-anchor="middle"
              class="font-heading translate-y-1 fill-black text-[48px] font-extrabold tracking-tight transition-transform md:translate-y-8 md:text-[88px]"
            >
              your trade show success
            </text>
          </g>
        </mask>
      </defs>

      <!-- Black rectangle with mask applied -->
      <rect width="100%" height="100%" fill="black" mask="url(#hero-text-mask)"
      ></rect>
    </svg>
  </div>

  <!-- 3. Scroll Indicator Hint -->
  <div
    id="hero-scroll-hint"
    class="pointer-events-none absolute bottom-10 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-white/60 transition-opacity duration-300"
  >
    <span class="text-xs font-light tracking-widest uppercase"
      >Scroll to explore</span
    >
    <svg
      class="text-accent h-5 w-5 animate-bounce"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const textGroup = document.getElementById("hero-text-group");
  const maskWrapper = document.getElementById("hero-mask-wrapper");
  const scrollHint = document.getElementById("hero-scroll-hint");
  const mainHeader = document.getElementById("main-header");

  if (textGroup && maskWrapper && mainHeader) {
    const isMobile = window.innerWidth < 768;
    const scrollDistance = isMobile ? "+=850" : "+=1200";
    const scrub = isMobile ? 0.8 : 1.2;
    const targetScale = isMobile ? 80 : 120;

    const showHeader = () => {
      mainHeader.classList.remove("-translate-y-full", "pointer-events-none");
      mainHeader.classList.add("translate-y-0");
    };

    const hideHeader = () => {
      mainHeader.classList.remove("translate-y-0");
      mainHeader.classList.add("-translate-y-full", "pointer-events-none");
    };

    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: "#hero-pin-container",
        start: "top top",
        end: scrollDistance,
        scrub: scrub,
        pin: true,
        anticipatePin: 1,
        onUpdate: (self) => {
          // Fade scroll hint
          if (scrollHint) {
            scrollHint.style.opacity = (1 - self.progress * 8).toString();
          }

          // Hide header while actively scrubbing through hero zoom, show when at the very top
          if (self.progress > 0.02 && self.progress < 0.98) {
            hideHeader();
          } else if (self.progress <= 0.02) {
            showHeader();
          }
        },
        onLeave: showHeader,      // Reappear when hero finishes and unpins
        onEnterBack: hideHeader,  // Hide again if scrolling back into hero zoom
        onLeaveBack: showHeader, // Reappear if scrolling all the way back to top
      },
    });

    timeline.to(
      textGroup,
      {
        scale: targetScale,
        transformOrigin: "50% 50%",
        ease: "power2.in",
      },
      0
    );

    timeline.to(
      maskWrapper,
      {
        opacity: 0,
        ease: "power1.inOut",
      },
      0
    );
  }
</script>