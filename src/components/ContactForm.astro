---

---

<section class="relative px-8 py-16 lg:px-16">
  <h2 class="mb-8 font-heading text-5xl font-thin text-accent">Contact</h2>

  <form method="post" class="relative z-10 flex flex-col gap-6 bg-black lg:p-2">
    <div class="flex flex-col gap-6 lg:flex-row lg:gap-12">
      <div class="flex items-stretch">
        <label for="name" class="bg-[#7f3500] text-lg flex items-center w-28 px-5 select-none lg:w-32 border border-[#e59053]">name</label>
        <input
          aria-label="Name"
          type="text"
          name="name"
          class="w-full border border-white/75 text-lg border-l-0 p-3 transition outline-none focus:border-accent focus:ring-1 focus:ring-accent lg:w-64"
        />
      </div>
      <div class="flex items-stretch">
        <label for="email" class="bg-[#7f3500] text-lg flex items-center w-28 px-5 select-none lg:w-32 border border-[#e59053]">email</label>
        <input
          aria-label="Email"
          type="email"
          name="email"
          class="w-full border border-white/75 text-lg border-l-0 p-3 transition outline-none focus:border-accent focus:ring-1 focus:ring-accent lg:w-64"
        />
      </div>
    </div>
    <textarea
      aria-label="Message"
      rows="5"
      name="message"
      placeholder="message"
      class="text-lg border border-white/75 p-3 transition outline-none focus:border-accent focus:ring-1 focus:ring-accent"
    ></textarea>
    <button
      type="submit"
      class="ml-auto w-fit cursor-pointer border border-accent/15 p-3 px-12 text-lg bg-accent/50"
      >send</button
    >
  </form>
</section>
