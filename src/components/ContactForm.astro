---

---

<section class="relative px-8 py-16 lg:px-16">
  <h2 class="mb-8 text-5xl font-thin text-[var(--color-accent)]">Contact</h2>

  <form method="post" class="relative z-10 flex flex-col gap-6 bg-black lg:p-2">
    <div class="flex flex-col gap-6 lg:flex-row lg:gap-12">
      <div class="flex items-stretch">
        <label for="name" class="bg-[#7f3500] flex items-center text-gray-300 w-28 px-5 select-none lg:w-32 border border-[#e59053]">Name</label>
        <input
          aria-label="Name"
          type="text"
          name="name"
          class="w-full border border-gray-300 border-l-0 p-3 transition outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] lg:w-64"
        />
      </div>
      <div class="flex items-stretch">
        <label for="email" class="bg-[#7f3500] flex items-center text-gray-300 w-28 px-5 select-none lg:w-32 border border-[#e59053]">Email</label>
        <input
          aria-label="Email"
          type="email"
          name="email"
          class="w-full border border-gray-300 border-l-0 p-3 transition outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] lg:w-64"
        />
      </div>
    </div>
    <textarea
      aria-label="Message"
      rows="5"
      name="message"
      placeholder="Message"
      class="border border-gray-300 p-3 transition outline-none placeholder:text-gray-300 focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)]"
    ></textarea>
    <button
      type="submit"
      class="ml-auto w-fit cursor-pointer border border-[var(--color-accent)] p-3 px-12 text-[var(--color-accent)] hover:bg-(--color-accent)/20"
      >SEND</button
    >
  </form>
</section>
